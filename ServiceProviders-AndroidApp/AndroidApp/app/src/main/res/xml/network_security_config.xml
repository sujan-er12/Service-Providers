<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allows both http and https so the WebView never blocks the site
         (some free hosts serve a mix of http/https resources). -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
